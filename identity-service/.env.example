APP_NAME=Turkuaz Identity
ENVIRONMENT=development
DATABASE_URL=sqlite:///./data/identity.db
SECRET_KEY=dev-change-me-32-byte-secret-key-for-turkuaz-identity
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720
AUTO_CREATE_SCHEMA=true
AUTO_CREATE_ADMIN=true
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_FULL_NAME=Platform Admin
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:6750","http://127.0.0.1:6750","http://localhost:5177","http://127.0.0.1:5177"]
